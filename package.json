{
  "name": "hub-de-obras",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@azure/msal-browser": "^3.12.0",
    "@azure/msal-react": "^2.0.12",
    "@hub/shared": "file:shared-types",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.91",
    "@types/react": "^18.2.71",
    "@types/react-dom": "^18.2.22",
    "axios": "^1.6.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "typescript": "^4.9.5",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "dev:all": "concurrently \"npm run dev -w hub-core\" \"npm run dev -w bff\" \"npm run dev -w hub-integrator\" \"npm start\"",
    "build": "npm run build -w shared-types && react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "deploy:backend": "npm run build --workspaces",
    "kill": "powershell -ExecutionPolicy Bypass -File kill-ports.ps1"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "workspaces": [
    "hub-core",
    "bff",
    "hub-consumer",
    "shared-types",
    "hub-integrator"
  ],
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.59.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15"
  }
}
